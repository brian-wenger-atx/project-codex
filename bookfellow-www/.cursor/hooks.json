{
  "version": 1,
  "hooks": {
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/www-feed-lanes-sync.sh",
        "matcher": "Read|TabRead"
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/www-feed-lanes-sync.sh",
        "matcher": "Read"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/www-feed-lanes-sync.sh",
        "matcher": "www-feed\\.md"
      }
    ],
    "postToolUse": [
      {
        "command": "/mnt/DataStore/.cursor/hooks/intake-fold-guard.sh",
        "matcher": "Write"
      },
      {
        "command": "/mnt/DataStore/.cursor/hooks/intake-fold-guard.sh",
        "matcher": "StrReplace"
      }
    ]
  }
}
