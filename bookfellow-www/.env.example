# Env example — copy to `.env.local` for pnpm dev (never commit secrets)

# Redis — lab publishes loopback only; AUTH required after Plan 2
REDIS_PASSWORD=generate_a_long_random_string
REDIS_URL=redis://:generate_a_long_random_string@127.0.0.1:6379

# Postgres via PgBouncer (runtime — hard rule 3)
DATABASE_URL=postgresql://bookfellow:CHANGE_ME@127.0.0.1:6432/bookfellow

# Direct Postgres (migrations only — bypass pooler)
DATABASE_DIRECT_URL=postgresql://bookfellow:CHANGE_ME@127.0.0.1:5433/bookfellow

# Worker claim reclaim window (seconds)
JOB_CLAIM_STALE_SECONDS=60

# Stripe webhook stub (test/dummy OK)
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder

# Auth (M1) — Better Auth; required at runtime (fail-fast if unset/placeholder)
BETTER_AUTH_SECRET=generate_a_long_random_string
# Must match the URL browsers use to reach the lab app
BETTER_AUTH_URL=http://192.168.1.200:4003
BOOKFELLOW_APP_URL=http://192.168.1.200:4003
# Comma-separated emails that get role=admin on create
BOOKFELLOW_ADMIN_EMAILS=

NODE_ENV=development
