# Env example — copy to `.env.local` for pnpm dev (never commit secrets)

# Redis (lab publishes loopback only — see compose)
REDIS_URL=redis://127.0.0.1:6379

# Postgres via PgBouncer (runtime — hard rule 3)
DATABASE_URL=postgresql://projectcodex:CHANGE_ME@127.0.0.1:6432/projectcodex

# Direct Postgres (migrations only — bypass pooler)
DATABASE_DIRECT_URL=postgresql://projectcodex:CHANGE_ME@127.0.0.1:5433/projectcodex

# Worker claim reclaim window (seconds)
JOB_CLAIM_STALE_SECONDS=60

# Stripe webhook stub (test/dummy OK)
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder

NODE_ENV=development
